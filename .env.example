cd ~/ai-career-accelerator

# Create .env.example
cat > .env.example << 'EOF'
# DATABASE
DATABASE_URL=sqlite:///./career_accelerator.db
APP_ENV=development
LOG_LEVEL=INFO

# AI API KEYS - Get from:
# - Groq: https://console.groq.com
# - Gemini: https://aistudio.google.com
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# AI MODEL
GEMINI_MODEL=llama-3.3-70b-versatile

# JWT AUTHENTICATION
SECRET_KEY=your_random_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# PDF PROCESSING
MAX_PDF_SIZE_BYTES=10485760
EOF

# Commit
git add .env.example
git commit -m "Add .env.example configuration template for Phase 3"
git push origin main

# Create PR to organization repo
